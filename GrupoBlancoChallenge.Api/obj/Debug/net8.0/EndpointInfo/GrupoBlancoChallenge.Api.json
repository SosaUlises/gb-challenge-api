{
  "openapi": "3.0.4",
  "info": {
    "title": "GrupoBlancoChallenge.Api",
    "version": "1.0"
  },
  "paths": {
    "/api/Game/start": {
      "post": {
        "tags": [
          "Game"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartGameRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/StartGameRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/StartGameRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/GameSessionResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GameSessionResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/GameSessionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/Game/{gameSessionId}": {
      "get": {
        "tags": [
          "Game"
        ],
        "parameters": [
          {
            "name": "gameSessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/GameSessionResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GameSessionResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/GameSessionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/Game/choose-option": {
      "post": {
        "tags": [
          "Game"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChooseOptionRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ChooseOptionRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ChooseOptionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/DecisionResultResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DecisionResultResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/DecisionResultResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/Ranking": {
      "get": {
        "tags": [
          "Ranking"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RankingResponse"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RankingResponse"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RankingResponse"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ChooseOptionRequest": {
        "type": "object",
        "properties": {
          "gameSessionId": {
            "type": "string",
            "format": "uuid"
          },
          "optionId": {
            "type": "string",
            "format": "uuid"
          }
        },
        "additionalProperties": false
      },
      "DecisionOptionResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "text": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "DecisionResultResponse": {
        "type": "object",
        "properties": {
          "consequence": {
            "type": "string",
            "nullable": true
          },
          "gameSession": {
            "$ref": "#/components/schemas/GameSessionResponse"
          }
        },
        "additionalProperties": false
      },
      "GameSessionResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "playerName": {
            "type": "string",
            "nullable": true
          },
          "rentability": {
            "type": "integer",
            "format": "int32"
          },
          "clients": {
            "type": "integer",
            "format": "int32"
          },
          "organizationalClimate": {
            "type": "integer",
            "format": "int32"
          },
          "brandImage": {
            "type": "integer",
            "format": "int32"
          },
          "operationalEfficiency": {
            "type": "integer",
            "format": "int32"
          },
          "currentScenarioOrder": {
            "type": "integer",
            "format": "int32"
          },
          "isFinished": {
            "type": "boolean"
          },
          "finalScore": {
            "type": "integer",
            "format": "int32"
          },
          "finalRating": {
            "type": "string",
            "nullable": true
          },
          "currentScenario": {
            "$ref": "#/components/schemas/ScenarioResponse"
          }
        },
        "additionalProperties": false
      },
      "RankingResponse": {
        "type": "object",
        "properties": {
          "playerName": {
            "type": "string",
            "nullable": true
          },
          "finalScore": {
            "type": "integer",
            "format": "int32"
          },
          "finalRating": {
            "type": "string",
            "nullable": true
          },
          "playedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "ScenarioResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "order": {
            "type": "integer",
            "format": "int32"
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "topic": {
            "type": "string",
            "nullable": true
          },
          "options": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DecisionOptionResponse"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "StartGameRequest": {
        "type": "object",
        "properties": {
          "playerName": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}